{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=60, s-maxage=60"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/refresh-feeds",
      "schedule": "*/15 * * * *"
    }
  ]
}
